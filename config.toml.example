# Terminal Manager — application configuration
# Copy to ~/.terminalmanager/config.toml or set TERMINALMANAGER_CONFIG to this file.
# Session profiles are stored separately; see [sessions].file below.

[app]
version = 1
single_instance = false  # true = one app instance per config directory

[window]
start_maximized = false  # open window zoomed on launch
restore_position = true  # persist frame/zoom in window-state.json

[terminal]
font_name = "Menlo"              # monospace font family
font_size = 12                   # terminal font point size
theme = "system"                 # system | light | dark
restore_tabs_on_launch = false   # restore tabs from launch-state.json
auto_reconnect = true            # prompt to reconnect when a session exits unexpectedly

[ui]
show_sidebar = true
show_command_bar = true  # send-command toolbar above tab strip
show_tooltips = true     # hover help text on buttons and controls
broadcast_enabled = true # enables broadcast/command bar feature
confirm_on_exit = false  # prompt before quitting

[sessions]
file = "sessions.json"   # relative to config dir, or absolute path
# sync_path = "~/Library/Mobile Documents/com~apple~CloudDocs/terminalmanager/sessions.json"

[logging]
level = "info"           # debug | info | warning | error
log_terminal_io = true   # write terminal input/output to logs/terminal-io-*.log
terminal_io_max_mb = 50  # rotate terminal I/O log when it exceeds this size

[performance]
launch_state_debounce_ms = 500      # coalesce launch-state.json writes
sidebar_search_debounce_ms = 150    # sidebar filter debounce
max_scrollback_lines = 10000        # terminal scrollback cap per tab
sessions_save_off_main = true       # encode/write sessions.json off main thread
hibernate_inactive_tabs_minutes = 30  # 0 = disable; terminate PTY for hidden tabs after N minutes
terminal_io_metadata_only = false   # log byte counts instead of terminal content
defer_sessions_load = true          # load sessions.json when sidebar opens (faster cold launch)
stagger_tab_restore = true          # restore tabs in batches on launch
stagger_tab_restore_batch_size = 3
find_debounce_ms = 200              # debounce ⌘F search input
broadcast_batch_delay_ms = 15       # delay between broadcast targets (ms)
config_schema_version = 2           # internal schema version (managed by app)
copy_on_select = false              # copy selected terminal text to clipboard
paste_on_middle_click = true        # middle-click pastes clipboard
stale_tab_minutes = 5               # 0 = off; mark tabs stale without output
session_recording_enabled = false   # plain-text or asciinema recordings in logs/recordings
session_recording_format = "plain"  # plain | asciinema
check_for_updates = true            # check GitHub releases on launch
update_repository = "terminalmanager/terminalmanager"

# Optional custom ANSI palette (requires non-default colors to persist)
# [performance.ansi_palette]
# black = "#000000"
# red = "#CC0000"

# Reusable SSH bastion / jump-host profiles
# [[bastions]]
# id = "00000000-0000-0000-0000-000000000001"
# name = "Corp Bastion"
# host = "bastion.example.com"
# username = "alice"
# port = 22

[[shortcuts]]
id = "newTab"
key = "t"
modifiers = ["command"]

[[shortcuts]]
id = "closeTab"
key = "w"
modifiers = ["command"]

[[shortcuts]]
id = "nextTab"
key = "]"
modifiers = ["command", "shift"]

[[shortcuts]]
id = "prevTab"
key = "["
modifiers = ["command", "shift"]

[[shortcuts]]
id = "duplicateSession"
key = "d"
modifiers = ["command"]

[[shortcuts]]
id = "commandBar"
key = "l"
modifiers = ["command", "shift"]
